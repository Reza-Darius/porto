[Unit]
Description=Porto proxy server
After=network.target
Documentation=https://github.com/Reza-Darius/porto

[Service]
Type=notify
User=porto
Group=porto

Environment="RUST_LOG=info"
ExecStart=/usr/local/bin/porto run

TimeoutStartSec=10
TimeoutStopSec=30
Restart=on-failure
RestartSec=5
NotifyAccess=main

RuntimeDirectory=porto

PrivateTmp=true
ProtectSystem=full
NoNewPrivileges=true
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
